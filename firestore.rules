rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /maps/{mapId} {
      function isOwner() {
        return request.auth != null && resource.data.ownerId == request.auth.uid;
      }

      allow read: if isOwner();
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner() && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isOwner();

      // nodes, connections, ideas — tilgang styres av eierskap til kartet
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/maps/$(mapId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
